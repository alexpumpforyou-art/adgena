{
	# Global config
	email admin@adgena.pro
}

# === MAIN PROXY ===
adgena.pro, www.adgena.pro {
	encode gzip zstd

	# Limit upload size (image generation)
	request_body {
		max_size 25MB
	}

	# Reverse proxy to Railway
	reverse_proxy {$RAILWAY_UPSTREAM} {
		# Use HTTPS upstream
		transport http {
			tls
			tls_server_name {$RAILWAY_HOST}
		}

		# Forward client info
		header_up Host {$RAILWAY_HOST}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}

		# Timeouts (AI generation can be slow)
		transport http {
			dial_timeout 30s
			response_header_timeout 60s
			read_timeout 120s
		}
	}

	# Logging
	log {
		output file /data/access.log {
			roll_size 50MB
			roll_keep 5
		}
		format console
		level INFO
	}
}
